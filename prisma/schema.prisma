generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  spaces   Space[]
  loginCodes LoginCode[]
  sessions   Session[]
}

model Space {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  isArchived Boolean @default(false)
  currentMonthTransactionCount Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transactions   Transaction[]
  transferTransactions Transaction[] @relation("TransactionTransferSpace")

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id          String    @id @default(cuid())
  type        String    // "income" or "expense"
  spaceId   String
  space     Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transferSpaceId String?
  transferSpace Space? @relation("TransactionTransferSpace", fields: [transferSpaceId], references: [id], onDelete: SetNull)
  description String
  amount      Float
  beginDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([spaceId])
  @@index([transferSpaceId])
  @@index([beginDate])
}

model LoginCode {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionTokenHash String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
