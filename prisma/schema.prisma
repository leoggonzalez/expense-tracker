generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserAccount {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  spaces   Space[]
  loginCodes LoginCode[]
  sessions   Session[]
}

enum SpaceType {
  credit_card
}

enum CreditCardPaymentTiming {
  same_month
  previous_month
}

model Space {
  id        String   @id @default(cuid())
  userAccountId    String
  userAccount      UserAccount     @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  name      String
  main      Boolean?
  type      SpaceType?
  paymentDueDay Int?
  paymentTiming CreditCardPaymentTiming?
  isArchived Boolean @default(false)
  currentMonthTransactionCount Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transactions   Transaction[]
  transferTransactions Transaction[] @relation("TransactionTransferSpace")

  @@unique([userAccountId, name])
  @@index([userAccountId])
}

model Transaction {
  id          String    @id @default(cuid())
  type        String    // "income" or "expense"
  spaceId   String
  space     Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transferSpaceId String?
  transferSpace Space? @relation("TransactionTransferSpace", fields: [transferSpaceId], references: [id], onDelete: SetNull)
  description String
  amount      Float
  beginDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([spaceId])
  @@index([transferSpaceId])
  @@index([beginDate])
}

model LoginCode {
  id         String   @id @default(cuid())
  userAccountId     String
  userAccount       UserAccount     @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userAccountId])
  @@index([email])
  @@index([expiresAt])
}

model Session {
  id               String   @id @default(cuid())
  userAccountId           String
  userAccount             UserAccount     @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  sessionTokenHash String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userAccountId])
  @@index([expiresAt])
}
